# Maxio Advanced Billing
MAXIO_API_KEY=your-maxio-api-key
MAXIO_SITE_SUBDOMAIN=your-test-site
MAXIO_ENVIRONMENT=US
MAXIO_DEFAULT_PRODUCT_FAMILY=metermate

# Slack (bot-token app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_OAUTH_CLIENT_ID=your-slack-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-client-secret
SLACK_OAUTH_REDIRECT_URI=http://localhost:4000/oauth/callback
SLACK_DIGEST_CHANNEL=C0XXXXXXX

# Admin (placeholder auth)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# App
PORT=4000
SESSION_TTL_MINUTES=30
DEMO_MODE=true
DIGEST_CRON=0 9 * * 1
